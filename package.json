{
  "name": "ble-collar-remote",
  "version": "1.0.0",
  "description": "BLE training collar controller using Nordic UART Service",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:server": "node server.js",
    "forwarder": "node forwarder.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:dir": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@stoprocent/noble": "^2.3.10",
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.ble-collar-remote.app",
    "productName": "BLE Collar Remote",
    "files": [
      "server.js",
      "forwarder.js",
      "lib/**/*",
      "devices/**/*",
      "public/**/*",
      "electron/**/*",
      "config.example.json",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "config.example.json",
        "to": "config.example.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "identity": null
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
